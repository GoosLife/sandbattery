# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=db_name
MYSQL_USER=db_user
MYSQL_PASSWORD=password

# Backend Configuration
BACKEND_PORT=0000
BACKEND_IMAGE=backend_image:latest

# Frontend Configuration
FRONTEND_PORT=1111
FRONTEND_IMAGE=frontend_image:latest

# Database Service Configuration
DB_SERVICE_NAME=db
DB_PORT=3306
DB_HOST=db

# Connection Strings
DB_CONNECTION_STRING=Server=db;Port=3306;Database=db_name;User=db_user;Password=password;

# Cloudflared Configuration
CLOUDFLARED_TOKEN=your_cloudflared_token_here